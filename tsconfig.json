{
  "compilerOptions": {
    "target": "ES2022", // ~node10
    "module": "CommonJS",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noImplicitAny": false
  },
  "include": [
    "src/"
, "src/schemas"  ],
  "exclude": [
    "**/*.spec.ts",
    "node_modules"
  ]
}
