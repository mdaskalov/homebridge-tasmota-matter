{
  "displayName": "Homebridge Tasmota Matter",
  "name": "homebridge-tasmota-matter",
  "version": "0.0.14",
  "description": "Control Tasmota Devices Using Matter",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/mdaskalov/homebridge-tasmota-matter.git"
  },
  "bugs": {
    "url": "https://github.com/mdaskalov/homebridge-tasmota-matter/issues"
  },
  "engines": {
    "node": "^v22 || ^v24",
    "homebridge": "^1.6.0 || ^2.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**.ts --max-warnings=0",
    "watch": "npm run build && npm link && nodemon",
    "generateSchema": "ts-json-schema-generator --path 'src/shemas/tasmotaDevice.ts' --type 'TasmotaDeviceSchema' --out 'src/schemas/tasmota-device.json' --no-top-ref",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "npm run build && node dist/index.js && echo \"No syntax errors! (node $(node -v))\""
  },
  "keywords": [
    "homebridge-plugin",
    "tasmota",
    "matter"
  ],
  "dependencies": {
    "ajv": "^8.20.0",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "homebridge": "^2.0.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.4",
    "rimraf": "^6.0.1",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
